            <settingConfig type="list">
                <listEntry value="0xFFFFFF">bianco1</listEntry>
                <listEntry value="0xFFFF00">giallo3</listEntry>
                <listEntry value="0xFF8800">arancione3</listEntry>
                <listEntry value="0x55FFFF">ciano2</listEntry>
                <listEntry value="0xFF0055">rosa3</listEntry>
                <listEntry value="0x888888">grigio4</listEntry>
                <listEntry value="0x000000">nero2</listEntry>
