    <group id="gruppoAttivita1" title="Anello ESTERNO">

        <setting propertyKey="@Properties.monitoringAttivita1" title="Tipologia Attivita 1">
            <settingConfig type="list">
                <listEntry value="0">Passi</listEntry>
                <listEntry value="1">Calorie</listEntry>
                <listEntry value="2">Piani Saliti</listEntry>
                <listEntry value="3">Minuti Attivita Settimana</listEntry>
                <listEntry value="4">Minuti Attivita Giorno</listEntry>
                <listEntry value="5">Stress</listEntry>
                <listEntry value="6">Body Battery</listEntry>
            </settingConfig>
        </setting>

        <setting propertyKey="@Properties.coloreSfondoAttivita1" title="Colore Sfondo Anello Esterno">
            <settingConfig type="list">
                <listEntry value="0x333333">grigio6</listEntry>
                <listEntry value="0x111111">nero1</listEntry>
                <listEntry value="0x000000">nero2</listEntry>
                <listEntry value="0x442211">marrone4</listEntry>
                <listEntry value="0x005555">ciano5</listEntry>
                <listEntry value="0x888800">giallo5</listEntry>
                <listEntry value="0x550000">rosso6</listEntry>
                <listEntry value="0x002200">verde6</listEntry>
                <listEntry value="0x000022">blu6</listEntry>
                <listEntry value="0x330055">viola5</listEntry>
                <listEntry value="0xFFFFFF">bianco1</listEntry>
