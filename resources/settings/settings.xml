<settings xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="https://developer.garmin.com/downloads/connect-iq/resources.xsd">

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!-- FORMATO ORE                                                  -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <setting propertyKey="@Properties.UseMilitaryFormat" title="Formato ore Militare">
        <settingConfig type="boolean" />
    </setting>

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!-- BACKGROUND                                                   -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <group id="GruppoBackground" title="Sfondo Quadrante">
        <setting propertyKey="@Properties.BackgroundColor" title="Background Color">
            <settingConfig type="list">
                <listEntry value="0x000000">@Strings.ColorBlack</listEntry>
                <listEntry value="0x555555">@Strings.ColorDarkGray</listEntry>
                <listEntry value="0xAAAAAA">@Strings.ColorLightGray</listEntry>
                <listEntry value="0xFFFFFF">@Strings.ColorWhite</listEntry>
            </settingConfig>
        </setting>
    </group>

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!-- TEMI                                                         -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <group id="GruppoTemiQuadrante" title="Temi quadrante">
        <setting propertyKey="@Properties.temiQuadrante" title="Temi Quadrante">
            <settingConfig type="list">
                <listEntry value="0">@Strings.Tema0</listEntry>
                <listEntry value="1">@Strings.Tema1</listEntry>
                <listEntry value="2">@Strings.Tema2</listEntry>
                <listEntry value="3">@Strings.Tema3</listEntry>
                <listEntry value="4">@Strings.Tema4</listEntry>
                <listEntry value="5">@Strings.Tema5</listEntry>
                <listEntry value="6">@Strings.Tema6</listEntry>
                <listEntry value="7">@Strings.Tema7</listEntry>
                <listEntry value="8">@Strings.Tema8</listEntry>
            </settingConfig>
        </setting>
    </group>

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!-- GOAL                                                         -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <group id="gruppoGOAL" title="GOAL">
        <setting propertyKey="@Properties.goalSTEP" title="@Strings.TitoloGoalSTEP">
            <settingConfig type="numeric" min="0" max="20000" />
        </setting>
        <setting propertyKey="@Properties.goalCALORIE" title="@Strings.TitoloGoalCALORIE">
            <settingConfig type="numeric" min="0" max="3000" />
        </setting>
        <setting propertyKey="@Properties.goalSTAIRS" title="@Strings.TitoloGoalSTAIRS">
            <settingConfig type="numeric" min="0" max="20" />
        </setting>
        <setting propertyKey="@Properties.goalMINWEEK" title="@Strings.TitoloGoalMINWEEK">
            <settingConfig type="numeric" min="0" max="500" />
        </setting>
        <setting propertyKey="@Properties.goalMINDAY" title="@Strings.TitoloGoalMINDAY">
            <settingConfig type="numeric" min="0" max="60" />
        </setting>
    </group>

